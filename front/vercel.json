{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "ignoreCommand": "[ \"$VERCEL_FORCE_NO_BUILD_CACHE\" != \"1\" ] && [ -n \"$VERCEL_GIT_PREVIOUS_SHA\" ] && [ \"$VERCEL_GIT_PREVIOUS_SHA\" != \"$VERCEL_GIT_COMMIT_SHA\" ] && ! git diff $VERCEL_GIT_PREVIOUS_SHA HEAD --name-only | grep -q '^front/'",
  "rewrites": [
    { "source": "/(.*)", "destination": "/" }
  ]
}
